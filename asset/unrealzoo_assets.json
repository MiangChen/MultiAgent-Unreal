  "api_commands": {
    "object": {
      "get_location": "vget /object/{name}/location",
      "set_location": "vset /object/{name}/location {x} {y} {z}",
      "get_rotation": "vget /object/{name}/rotation",
      "set_rotation": "vset /object/{name}/rotation {pitch} {yaw} {roll}",
      "spawn": "vset /objects/spawn {class_name} {name}"
    },
    "blueprint": {
      "set_move": "vbp {name} set_move {params}",
      "set_appearance": "vbp {name} set_app {id}",
      "nav_to_goal": "vbp {name} nav_to_goal {x} {y} {z}",
      "set_physics": "vbp {name} set_phy {0|1}",
      "set_scale": "vbp {name} set_scale {x} {y} {z}"
    },
    "camera": {
      "get_image": "vget /camera/{id}/{mode} {format}",
      "get_location": "vget /camera/{id}/location",
      "set_location": "vset /camera/{id}/location {x} {y} {z}",
      "get_rotation": "vget /camera/{id}/rotation",
