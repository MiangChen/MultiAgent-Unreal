{
    "simulation": {
        "name": "MultiAgent Simulation",
        "version": "1.0",
        "run_mode": "edit",
        "use_setup_ui": false,
        "use_state_tree": false,
        "enable_energy_drain": false,
        "map_type": "Downtown"
    },
    "spawn_settings": {
        "use_player_start": true,
        "fallback_origin": [0, 0, 100],
        "spawn_radius": 400,
        "project_to_navmesh": true
    },
    "navigation": {
        "path_planner_type": "ElevationMap",
        "multi_layer_raycast": {
            "layer_count": 3,
            "layer_distance": 300.0,
            "scan_angle_range": 120.0,
            "scan_angle_step": 15.0
        },
        "elevation_map": {
            "cell_size": 50.0,
            "search_radius": 1000.0,
            "max_slope_angle": 30.0,
            "max_step_height": 50.0,
            "path_smoothing_factor": 0.15
        }
    },
    "server": {
        "planner_url": "http://localhost:8081",
        "use_mock_data": false,
        "enable_polling": true,
        "enable_hitl_polling": true,
        "poll_interval_seconds": 1.0,
        "hitl_poll_interval_seconds": 1.0,
        "debug_mode": false,
        "local_server_port": 8080,
        "enable_local_server": true
    }
}
